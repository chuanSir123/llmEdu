{
  "name": "llm-edu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json && vite build --config client/vite.config.ts",
    "start": "node dist/main.js",
    "db:migrate": "tsx src/db/migrator.ts",
